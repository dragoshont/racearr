@inherits LayoutComponentBase
@implements IDisposable
@inject RaceEngineState State
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthProvider
@inject PersistentComponentState AppState

<MudThemeProvider Theme="@Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Default" Edge="Edge.Start"
                       aria-label="Toggle navigation" OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
        <MudText Typo="Typo.h6">racearr</MudText>
        <MudSpacer />
        @if (!string.IsNullOrEmpty(_userName))
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                     Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2">@_userName</MudChip>
        }
        @if (State.DryRun)
        {
            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Visibility">DRY-RUN</MudChip>
        }
        else
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Bolt">ARMED</MudChip>
        }
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Variant="@DrawerVariant.Persistent" Elevation="1" ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Tune">Settings</MudNavLink>
            <MudNavLink Href="/connections" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SettingsEthernet">Connections</MudNavLink>
            <MudNavLink Href="/history" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">History</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string? _userName;
    private PersistingComponentStateSubscription _persistSub;

    // The ingress path-splits the Blazor /_blazor circuit out of Authentik forward-auth (so the
    // realtime connection isn't killed), which makes the interactive circuit anonymous. Capture the
    // authenticated username during server-side rendering (the gated request) and persist it across
    // the SSR -> interactive boundary so the chip stays put instead of vanishing once the circuit
    // connects. (AddAuthenticationStateSerialization only helps WebAssembly, not InteractiveServer.)
    protected override async Task OnInitializedAsync()
    {
        _persistSub = AppState.RegisterOnPersisting(() =>
        {
            AppState.PersistAsJson(nameof(_userName), _userName);
            return Task.CompletedTask;
        });

        if (AppState.TryTakeFromJson<string?>(nameof(_userName), out var restored))
        {
            _userName = restored; // interactive circuit: restore the name captured during SSR
        }
        else
        {
            var state = await AuthProvider.GetAuthenticationStateAsync(); // SSR: read the gated identity
            var id = state.User.Identity;
            _userName = id?.IsAuthenticated == true ? id.Name : null;
        }
    }

    public void Dispose() => _persistSub.Dispose();

    private static readonly MudTheme Theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#5aa9e6",
            AppbarBackground = "#1b2733",
            Background = "#151b23",
            Surface = "#1b2733",
            DrawerBackground = "#1b2733",
        },
    };
}
