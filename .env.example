# Copy to .env and fill in. Only the API keys are strictly required.
RADARR_API_KEY=
SONARR_API_KEY=

# qBittorrent WebUI login. Leave blank if qBit bypasses auth for this client
# (localhost bypass or a whitelisted subnet).
QBIT_USERNAME=
QBIT_PASSWORD=

# Optional: your private trackers, so racearr never races/removes them (H&R safety).
# PRIVATE_INDEXERS=passthepopcorn,broadcasthenet

# Optional notifications (see README). Discord webhooks are auto-detected; any
# other webhook URL receives {"text": ...}. ntfy needs both URL + topic.
# INCIDENT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=racearr
# NTFY_TOKEN=
# NTFY_PRIORITY=default

# Optional: extra *arr instances beyond the primary RADARR_*/SONARR_* above.
# ;-separated  kind|url|apikey|label  (label optional). Example: a 4K Radarr + anime Sonarr.
# ARR_INSTANCES=radarr|http://radarr-4k:7878|APIKEY|4k;sonarr|http://sonarr-anime:8989|APIKEY|anime
