{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "tags": ["media", "racearr"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "title": "racearr — pickup & download racing",
  "uid": "racearr",
  "panels": [
    {
      "type": "stat", "title": "State", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "max(racearr_dry_run)", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "0": { "text": "ARMED", "color": "green" }, "1": { "text": "DRY-RUN", "color": "yellow" } } }
      ], "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } } }
    },
    {
      "type": "stat", "title": "Active races", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(racearr_active_races)", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "type": "stat", "title": "Managed downloads", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(racearr_managed_downloads)", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "type": "stat", "title": "Incidents (24h)", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(increase(racearr_incidents_total[24h]))", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" }
    },
    {
      "type": "stat", "title": "Pickup SLA hit-rate", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(rate(racearr_pickups_total{result=\"in_sla\"}[$__range])) / (sum(rate(racearr_pickups_total[$__range])) > 0)", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "noValue": "—", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 0.95 } ] } } }
    },
    {
      "type": "stat", "title": "Race win-rate (>2 MB/s)", "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(rate(racearr_race_outcomes_total{outcome=\"won_target\"}[$__range])) / (sum(rate(racearr_race_outcomes_total[$__range])) > 0)", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "noValue": "—", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 } ] } } }
    },
    {
      "type": "timeseries", "title": "Pickup latency (added → grabbed)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(racearr_pickup_latency_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(racearr_pickup_latency_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "title": "Pickups by result", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum(rate(racearr_pickups_total[$__rate_interval])) by (result)", "legendFormat": "{{result}}", "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "Time to target speed (≥ RACE_TARGET_MBPS)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(racearr_time_to_target_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(racearr_time_to_target_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "title": "Races / candidates grabbed / losers killed", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum(rate(racearr_races_started_total[$__rate_interval]))", "legendFormat": "races started", "refId": "A" },
        { "expr": "sum(rate(racearr_candidates_grabbed_total[$__rate_interval]))", "legendFormat": "candidates grabbed", "refId": "B" },
        { "expr": "sum(rate(racearr_losers_killed_total[$__rate_interval]))", "legendFormat": "losers killed", "refId": "C" }
      ]
    },
    {
      "type": "timeseries", "title": "Race winner speed", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "MBs", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(racearr_race_winner_mbps_bucket[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(racearr_race_winner_mbps_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "title": "Incidents by type", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum(rate(racearr_incidents_total[$__rate_interval])) by (type)", "legendFormat": "{{type}}", "refId": "A" } ]
    },
    {
      "type": "logs", "title": "racearr activity (incidents · grabs · kills)", "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "expr": "{k8s_deployment_name=\"racearr\"} |~ \"INCIDENT|GRAB|KILL|racing|baseline\"", "refId": "A" } ]
    }
  ]
}
